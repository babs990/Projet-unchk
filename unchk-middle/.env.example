# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unchk_db
DB_USER=unchk_user
DB_PASSWORD=unchk_password
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=unchk_super_secret_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=unchk_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Upload fichiers ───────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
