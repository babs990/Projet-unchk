# ─── Service UNCHK Backend (génération PDF) ──────────────────────────────────
# Ce service est stateless : il n'a pas d'accès direct à PostgreSQL.
# Il ne fait que recevoir du JSON et renvoyer des PDF au Middle Tier.

# Port d'écoute
PORT=8081

# Token interne partagé avec le Middle Tier Express.js
# DOIT être identique à la valeur que le middle enverra dans le header
# X-Internal-Token sur chaque appel à ce service.
INTERNAL_SERVICE_TOKEN=changez_ce_token_partage_avec_le_middle
